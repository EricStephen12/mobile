{
  "expo": {
    "name": "Eixora",
    "slug": "eixora",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/new_premium_icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.eixora.mobile"
    },
    "android": {
      "package": "com.eixora.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#050505",
        "foregroundImage": "./assets/images/new_premium_icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/new_premium_icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050505",
          "image": "./assets/images/new_premium_icon.png",
          "imageWidth": 200,
          "android": {
            "image": "./assets/images/new_premium_icon.png",
            "imageWidth": 200
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Singsong.otf"
          ]
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false
          }
        }
      ],
      "@sentry/react-native/expo",
      "@sentry/react-native",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "6adc592f-f358-4fa4-b66e-c38a8e196927"
      }
    }
  }
}
